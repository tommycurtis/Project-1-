using System;

class Program
{
    static void Main(string[] args)
    {
        Random rand = new Random();
        bool playing = true;

        while (playing)
        {
            int playerHealth = 100;
            int enemyHealth = 100;

            Console.Clear();
            Console.WriteLine("===== SIMPLE RPG BATTLE =====");
            Console.WriteLine("You encountered an enemy!\n");

            while (playerHealth > 0 && enemyHealth > 0)
            {
                Console.WriteLine($"Your Health: {playerHealth} | Enemy Health: {enemyHealth}");
                Console.WriteLine("1. Attack");
                Console.WriteLine("2. Heal");
                Console.WriteLine("3. Run");
                Console.Write("Choose an action: ");

                string choice = Console.ReadLine();
                Console.WriteLine();

                if (choice == "1") // Attack
                {
                    int playerDamage = rand.Next(10, 21);
                    int enemyDamage = rand.Next(5, 16);

                    enemyHealth -= playerDamage;
                    playerHealth -= enemyDamage;

                    Console.WriteLine($"You dealt {playerDamage} damage!");
                    Console.WriteLine($"Enemy dealt {enemyDamage} damage!");
                }
                else if (choice == "2") // Heal
                {
                    int healAmount = rand.Next(10, 21);
                    int enemyDamage = rand.Next(5, 16);

                    playerHealth += healAmount;
                    playerHealth -= enemyDamage;

                    Console.WriteLine($"You healed {healAmount} health!");
                    Console.WriteLine($"Enemy attacked for {enemyDamage} damage!");
                }
                else if (choice == "3") // Run
                {
                    Console.WriteLine("You ran away!");
                    break;
                }
                else
                {
                    Console.WriteLine("Invalid choice.");
                }

                Console.WriteLine("\nPress any key to continue...");
                Console.ReadKey();
                Console.Clear();
            }

            if (playerHealth <= 0)
            {
                Console.WriteLine("💀 You were defeated...");
            }
            else if (enemyHealth <= 0)
            {
                Console.WriteLine("🏆 You defeated the enemy!");
            }

            Console.Write("\nPlay again? (y/n): ");
            playing = Console.ReadLine().ToLower() == "y";
        }

        Console.WriteLine("\nThanks for playing!");
    }
}